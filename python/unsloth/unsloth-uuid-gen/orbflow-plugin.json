{
  "name": "unsloth-uuid-gen",
  "version": "0.2.0",
  "description": "Generate UUID v4 identifiers in multiple formats",
  "author": "Unsloth",
  "license": "Apache-2.0",
  "category": "utility",
  "tags": [
    "unsloth",
    "uuid",
    "id",
    "generator"
  ],
  "icon": "hash",
  "color": "#8B5CF6",
  "node_types": [
    "plugin:uuid-gen"
  ],
  "protocol": {
    "Grpc": {
      "default_port": 50051
    }
  },
  "language": "python",
  "orbflow_version": ">=0.1.0",
  "inputs": [],
  "outputs": [
    {
      "key": "uuid",
      "label": "UUID",
      "type": "string",
      "description": "Single generated UUID"
    },
    {
      "key": "uuids",
      "label": "UUIDs",
      "type": "array",
      "description": "Array of UUIDs when count > 1"
    },
    {
      "key": "count",
      "label": "Count",
      "type": "number",
      "description": "Number generated"
    }
  ],
  "parameters": [
    {
      "key": "count",
      "label": "Count",
      "type": "number",
      "description": "Number of UUIDs to generate (1-1000)",
      "default": 1
    },
    {
      "key": "format",
      "label": "Format",
      "type": "string",
      "description": "Output format: hyphenated, simple, urn, upper",
      "default": "hyphenated"
    }
  ]
}
