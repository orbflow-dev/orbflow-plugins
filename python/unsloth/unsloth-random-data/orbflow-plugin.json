{
  "name": "unsloth-random-data",
  "version": "0.2.0",
  "description": "Generate random numbers, categories, booleans, timestamps, and strings",
  "author": "Unsloth",
  "license": "Apache-2.0",
  "category": "utility",
  "tags": [
    "unsloth",
    "random",
    "generator",
    "testing",
    "mock"
  ],
  "icon": "dice",
  "color": "#06B6D4",
  "node_types": [
    "plugin:random-data"
  ],
  "protocol": {
    "Grpc": {
      "default_port": 50051
    }
  },
  "language": "python",
  "orbflow_version": ">=0.1.0",
  "inputs": [],
  "outputs": [
    {
      "key": "value",
      "label": "Value",
      "type": "object",
      "description": "Single generated value"
    },
    {
      "key": "values",
      "label": "Values",
      "type": "array",
      "description": "Array of values when count > 1"
    },
    {
      "key": "count",
      "label": "Count",
      "type": "number",
      "description": "Number generated"
    }
  ],
  "parameters": [
    {
      "key": "mode",
      "label": "Mode",
      "type": "string",
      "description": "Type: uniform, gaussian, category, boolean, datetime, string",
      "default": "uniform"
    },
    {
      "key": "count",
      "label": "Count",
      "type": "number",
      "description": "Number of values (1-10000)",
      "default": 1
    },
    {
      "key": "min",
      "label": "Min",
      "type": "number",
      "description": "Minimum for uniform mode",
      "default": 0
    },
    {
      "key": "max",
      "label": "Max",
      "type": "number",
      "description": "Maximum for uniform mode",
      "default": 100
    },
    {
      "key": "mean",
      "label": "Mean",
      "type": "number",
      "description": "Mean for gaussian mode",
      "default": 0
    },
    {
      "key": "std_dev",
      "label": "Std Dev",
      "type": "number",
      "description": "Standard deviation for gaussian mode",
      "default": 1
    },
    {
      "key": "categories",
      "label": "Categories",
      "type": "string",
      "description": "Comma-separated categories for category mode",
      "default": "A,B,C"
    },
    {
      "key": "string_length",
      "label": "String Length",
      "type": "number",
      "description": "Length for string mode",
      "default": 8
    }
  ]
}
