{
  "name": "orbflow-schema-transform",
  "version": "0.2.0",
  "description": "Reshape data rows using field mapping, templates, and filtering",
  "author": "Orbflow",
  "license": "Apache-2.0",
  "category": "data-processing",
  "tags": [
    "transform",
    "mapping",
    "etl"
  ],
  "icon": "filter",
  "color": "#0EA5E9",
  "node_types": [
    "plugin:schema-transform"
  ],
  "protocol": {
    "Grpc": {
      "default_port": 50051
    }
  },
  "language": "python",
  "orbflow_version": ">=0.1.0",
  "inputs": [
    {
      "key": "rows",
      "label": "Rows",
      "type": "array",
      "required": true,
      "description": "Input array of row objects to transform"
    },
    {
      "key": "mapping",
      "label": "Field Mapping",
      "type": "object",
      "description": "JSON mapping: {\"new_field\": \"source_field\"}"
    }
  ],
  "outputs": [
    {
      "key": "rows",
      "label": "Rows",
      "type": "array",
      "description": "Transformed rows"
    },
    {
      "key": "row_count",
      "label": "Row Count",
      "type": "number"
    },
    {
      "key": "columns",
      "label": "Columns",
      "type": "array",
      "description": "Output column names"
    }
  ],
  "parameters": [
    {
      "key": "drop_unmapped",
      "label": "Drop Unmapped",
      "type": "boolean",
      "description": "Drop fields not in the mapping",
      "default": true
    },
    {
      "key": "template",
      "label": "Template",
      "type": "string",
      "description": "Jinja2-style template for computed fields: {{field}}"
    },
    {
      "key": "template_field",
      "label": "Template Field",
      "type": "string",
      "description": "Name of the field to store the template result",
      "default": "computed"
    }
  ]
}
