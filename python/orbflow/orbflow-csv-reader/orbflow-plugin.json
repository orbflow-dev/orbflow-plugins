{
  "name": "orbflow-csv-reader",
  "version": "0.2.0",
  "description": "Parse CSV, JSON, and JSONL data into structured rows",
  "author": "Orbflow",
  "license": "Apache-2.0",
  "category": "data-source",
  "tags": [
    "csv",
    "json",
    "jsonl",
    "parser"
  ],
  "icon": "file-text",
  "color": "#10B981",
  "node_types": [
    "plugin:csv-reader"
  ],
  "protocol": {
    "Grpc": {
      "default_port": 50051
    }
  },
  "language": "python",
  "orbflow_version": ">=0.1.0",
  "inputs": [
    {
      "key": "content",
      "label": "Content",
      "type": "string",
      "required": true,
      "description": "Raw CSV, JSON array, or JSONL text to parse"
    }
  ],
  "outputs": [
    {
      "key": "rows",
      "label": "Rows",
      "type": "array",
      "description": "Parsed array of row objects"
    },
    {
      "key": "columns",
      "label": "Columns",
      "type": "array",
      "description": "Column/field names"
    },
    {
      "key": "row_count",
      "label": "Row Count",
      "type": "number"
    }
  ],
  "parameters": [
    {
      "key": "format",
      "label": "Format",
      "type": "string",
      "description": "Input format: auto, csv, json, jsonl",
      "default": "auto"
    },
    {
      "key": "has_header",
      "label": "Has Header",
      "type": "boolean",
      "description": "Whether CSV has a header row",
      "default": true
    },
    {
      "key": "delimiter",
      "label": "Delimiter",
      "type": "string",
      "description": "CSV delimiter character",
      "default": ","
    },
    {
      "key": "max_rows",
      "label": "Max Rows",
      "type": "number",
      "description": "Maximum rows to parse (1-100000)",
      "default": 10000
    }
  ]
}
